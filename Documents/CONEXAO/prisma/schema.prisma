generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  engineType      = "binary"
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              Tenant  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Tenant   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tenant {
  id                      String        @id @default(uuid())
  name                    String?
  email                   String        @unique
  password                String?
  whatsapp                String?       @unique
  cpfCnpj                 String?
  role                    String        @default("user")
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  notificationPreferences String?
  botLimit               Int           @default(1)
  asaasApiKey            String?
  openaiApiKey           String?
  geminiApiKey           String?
  openrouterApiKey       String?
  accounts               Account[]
  bots                   Bot[]
  contacts               Contact[]
  payments               Payment[]
  sessions               Session[]
  subscription           Subscription?
  usageCounter           UsageCounter?
}

model Bot {
  id                String         @id @default(uuid())
  name              String
  businessType      String
  voiceId           String?
  modules           String[]
  status            String         @default("active")
  sessionName       String?        @unique
  address           String?
  hours             String?
  paymentMethods    String[]
  knowledgeBase     String?
  description       String?
  productsServices  String?
  websiteUrl        String?
  scrapedContent    String?
  lastScrapedAt     DateTime?
  enablePayments    Boolean        @default(false)
  fallbackContact   String?
  systemPrompt      String?
  aiProvider        String         @default("openai")
  aiModel           String         @default("gpt-4o-mini")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tenantId          String
  connectionStatus  String         @default("DISCONNECTED")
  webhookToken      String?
  webhookUrl        String?
  chatwootAccountId String?
  chatwootToken     String?
  chatwootUrl       String?
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  media             BotMedia[]
  conversations     Conversation[]
  orders            Order[]
  products          Product[]
  vectors           VectorStore[]
}

model BotMedia {
  id            String    @id @default(uuid())
  type          String
  filename      String
  url           String
  description   String?
  extractedText String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  botId         String
  bot           Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String?
  price       Float
  currency    String      @default("BRL")
  sku         String?
  stock       Int         @default(0)
  imageUrl    String?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  botId       String
  orderItems  OrderItem[]
  bot         Bot         @relation(fields: [botId], references: [id], onDelete: Cascade)
}

model Order {
  id          String      @id @default(uuid())
  status      String      @default("PENDING")
  totalAmount Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  botId       String
  contactId   String
  bot         Bot         @relation(fields: [botId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  items       OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Float
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Contact {
  id            String      @id @default(uuid())
  phone         String
  name          String?
  email         String?
  company       String?
  role          String?
  needs         String?
  notes         String?
  tags          String[]
  funnelStage   FunnelStage @default(LEAD)
  lastActive    DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tenantId      String
  lastAiInsight String?
  leadScore     Int         @default(0)
  sentiment     String?
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders        Order[]

  @@unique([phone, tenantId])
}

model Conversation {
  id        String    @id @default(uuid())
  channel   String
  remoteId  String
  status    String    @default("open")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  botId     String
  bot       Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([botId, remoteId])
}

model Message {
  id             String       @id @default(uuid())
  content        String
  role           String
  createdAt      DateTime     @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Subscription {
  id         String   @id @default(uuid())
  plan       String
  status     String
  gateway    String
  externalId String?
  tenantId   String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Payment {
  id         String   @id @default(uuid())
  amount     Float
  status     String
  gateway    String
  externalId String?
  invoiceUrl String?
  tenantId   String
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model UsageCounter {
  id            String   @id @default(uuid())
  messagesUsed  Int      @default(0)
  messagesLimit Int      @default(500)
  botsUsed      Int      @default(0)
  botsLimit     Int      @default(1)
  periodStart   DateTime @default(now())
  periodEnd     DateTime
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model VectorStore {
  id        String                 @id @default(uuid())
  content   String
  metadata  Json?
  embedding Unsupported("vector")?
  botId     String
  createdAt DateTime               @default(now())
  bot       Bot                    @relation(fields: [botId], references: [id], onDelete: Cascade)
}

enum FunnelStage {
  LEAD
  AWARENESS
  INTEREST
  CONSIDERATION
  DECISION
  ACTION
  CUSTOMER
  SUPPORT
  CHURNED
}
