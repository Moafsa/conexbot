generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              Tenant  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Tenant   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tenant {
  id                      String         @id @default(uuid())
  name                    String?
  email                   String         @unique
  password                String?
  whatsapp                String?        @unique
  cpfCnpj                 String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  notificationPreferences String?
  asaasApiKey             String?
  botLimit                Int            @default(1)
  geminiApiKey            String?
  openaiApiKey            String?
  openrouterApiKey        String?
  elevenLabsApiKey        String?
  role                    UserRole       @default(USER)
  asaasWalletId           String?
  resetToken              String?        @unique
  resetTokenExpires       DateTime?
  accounts                Account[]
  appointments            Appointment[]
  bots                    Bot[]
  botMaterials            BotMaterial[]
  contacts                Contact[]
  followupRules           FollowupRule[]
  payments                Payment[]
  sessions                Session[]
  smtpConfigs             SmtpConfig[]
  subscription            Subscription?
  usageCounter            UsageCounter?
  notifications           Notification[]
}

model Bot {
  id                  String             @id @default(uuid())
  name                String
  businessType        String
  voiceId             String?
  modules             String[]
  status              String             @default("active")
  sessionName         String?            @unique
  address             String?
  hours               String?
  paymentMethods      String[]
  knowledgeBase       String?
  description         String?
  productsServices    String?
  websiteUrl          String?
  scrapedContent      String?
  lastScrapedAt       DateTime?
  enablePayments      Boolean            @default(false)
  fallbackContact     String?
  systemPrompt        String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  tenantId            String
  aiModel             String             @default("gpt-4o-mini")
  aiProvider          String             @default("openai")
  chatwootAccountId   String?
  chatwootToken       String?
  chatwootUrl         String?
  connectionStatus    String             @default("DISCONNECTED")
  webhookToken        String?
  webhookUrl          String?
  messageBuffer       Int                @default(1500)
  appointmentDuration Int                @default(30)
  asaasApiKey         String?
  googleCalendarId    String?            @default("primary")
  googleRefreshToken  String?
  schedulingProvider  SchedulingProvider @default(INTERNAL)
  userSplitType       SplitType          @default(PERCENTAGE)
  userSplitValue      Float              @default(0)
  workingHours        Json?
  aiDetectionAction   String             @default("PAUSE")
  enableAiDetection   Boolean            @default(false)
  handoffPause        Int                @default(1440)
  humanTakeoverPause  Int                @default(30)
  notifyChannels      String             @default("INTERNAL,WHATSAPP,EMAIL")
  connectToken        String?            @unique
  allowedGroups       String[]           @default([])
  groupResponseMode   String             @default("ALL")
  appointments        Appointment[]
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  materials           BotMaterial[]
  media               BotMedia[]
  assignedContacts    Contact[]          @relation("AssignedBot")
  contacts            Contact[]
  conversations       Conversation[]
  crmStages           CrmStage[]
  followupRules       FollowupRule[]
  orders              Order[]
  products            Product[]
  smtpConfigs         SmtpConfig[]
  vectors             VectorStore[]
  coupons             Coupon[]

  // Hierarchy for Agent Isolation
  masterId            String?
  master              Bot?               @relation("BotAgents", fields: [masterId], references: [id])
  agents              Bot[]              @relation("BotAgents")
}

model Appointment {
  id            String            @id @default(uuid())
  startTime     DateTime
  endTime       DateTime
  status        AppointmentStatus @default(PENDING)
  googleEventId String?           @unique
  botId         String
  contactId     String?
  tenantId      String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  bot           Bot               @relation(fields: [botId], references: [id], onDelete: Cascade)
  contact       Contact?          @relation(fields: [contactId], references: [id])
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SmtpConfig {
  id        String   @id @default(uuid())
  host      String
  port      Int
  user      String
  pass      String
  fromEmail String
  active    Boolean  @default(true)
  tenantId  String
  botId     String?
  createdAt DateTime @default(now())
  bot       Bot?     @relation(fields: [botId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model FollowupRule {
  id          String   @id @default(uuid())
  name        String
  triggerDays Int      @default(1)
  triggerType String   @default("AFTER_LAST_MESSAGE")
  message     String
  active      Boolean  @default(true)
  botId       String
  tenantId    String
  createdAt   DateTime @default(now())
  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model BotMaterial {
  id            String   @id @default(uuid())
  name          String
  type          String
  contentUrl    String
  extractedText String?
  botId         String
  tenantId      String
  createdAt     DateTime @default(now())
  bot           Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model CrmStage {
  id          String    @id @default(uuid())
  name        String
  color       String    @default("gray")
  order       Int       @default(0)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  botId       String
  contacts    Contact[]
  bot         Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, name])
}

model BotMedia {
  id            String    @id @default(uuid())
  type          String
  filename      String
  url           String
  description   String?
  extractedText String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  botId         String
  bot           Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
}

model Product {
  id            String         @id @default(uuid())
  name          String
  description   String?
  price         Float
  salePrice     Float?
  currency      String         @default("BRL")
  sku           String?
  stock         Int            @default(0)
  imageUrl      String?
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  botId         String
  videoUrl      String?
  billingPeriod BillingPeriod?
  iterations    Int?
  type          ProductType    @default(SINGLE)
  orderItems    OrderItem[]
  bot           Bot            @relation(fields: [botId], references: [id], onDelete: Cascade)
}

model Coupon {
  id          String      @id @default(uuid())
  code        String
  type        CouponType  @default(PERCENTAGE)
  value       Float
  active      Boolean     @default(true)
  botId       String
  tenantId    String
  expiresAt   DateTime?
  usageLimit  Int?
  usedCount   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  bot         Bot         @relation(fields: [botId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@unique([botId, code])
  @@index([botId])
}

enum CouponType {
  PERCENTAGE
  FIXED
}

model Order {
  id               String      @id @default(uuid())
  status           String      @default("PENDING")
  totalAmount      Float
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  botId            String
  contactId        String
  commissionAmount Float?      @default(0)
  externalId       String?     @unique
  couponId         String?
  bot              Bot         @relation(fields: [botId], references: [id], onDelete: Cascade)
  contact          Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  coupon           Coupon?     @relation(fields: [couponId], references: [id])
  items            OrderItem[]

  @@index([couponId])
}

model OrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Float
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Contact {
  id            String        @id @default(uuid())
  phone         String
  name          String?
  email         String?
  company       String?
  role          String?
  needs         String?
  notes         String?
  tags          String[]
  lastActive    DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tenantId      String
  botId         String?
  lastAiInsight String?
  leadScore     Int           @default(0)
  sentiment     String?
  stageId       String?
  funnelStage   String        @default("LEAD")
  eventDate     DateTime?
  assignedBotId String?
  appointments  Appointment[]
  assignedBot   Bot?          @relation("AssignedBot", fields: [assignedBotId], references: [id])
  bot           Bot?          @relation(fields: [botId], references: [id], onDelete: Cascade)
  stage         CrmStage?     @relation(fields: [stageId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders        Order[]

  @@unique([phone, botId])
}

model Conversation {
  id        String    @id @default(uuid())
  channel   String
  remoteId  String
  status    String    @default("open")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  botId     String
  bot       Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([botId, remoteId])
}

model Message {
  id             String       @id @default(uuid())
  content        String
  role           String
  createdAt      DateTime     @default(now())
  conversationId String
  tool_call_id   String?
  tool_calls     Json?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Plan {
  id                 String         @id @default(uuid())
  name               String
  description        String?
  price              Float
  interval           PlanInterval   @default(MONTHLY)
  botLimit           Int            @default(1)
  messageLimit       Int            @default(5000)
  active             Boolean        @default(true)
  externalId         String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  platformSplitType  SplitType      @default(PERCENTAGE)
  platformSplitValue Float          @default(0)
  priceQuarterly     Float?
  priceSemiannual    Float?
  priceYearly        Float?
  trialDays          Int            @default(0)
  features           Json?          @default("[]")
  subscriptions      Subscription[]
}

model Subscription {
  id         String             @id @default(uuid())
  gateway    String             @default("ASAAS")
  externalId String?            @unique
  tenantId   String             @unique
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  planId     String?
  status     SubscriptionStatus
  plan       Plan?              @relation(fields: [planId], references: [id])
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Payment {
  id         String        @id @default(uuid())
  amount     Float
  gateway    String        @default("ASAAS")
  externalId String?       @unique
  invoiceUrl String?
  tenantId   String
  createdAt  DateTime      @default(now())
  status     PaymentStatus
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model UsageCounter {
  id            String   @id @default(uuid())
  messagesUsed  Int      @default(0)
  messagesLimit Int      @default(5000)
  botsUsed      Int      @default(0)
  botsLimit     Int      @default(1)
  periodStart   DateTime @default(now())
  periodEnd     DateTime
  tenantId      String   @unique
  warned100     Boolean  @default(false)
  warned90      Boolean  @default(false)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model VectorStore {
  id        String                 @id @default(uuid())
  content   String
  metadata  Json?
  embedding Unsupported("vector")?
  botId     String
  createdAt DateTime               @default(now())
  bot       Bot                    @relation(fields: [botId], references: [id], onDelete: Cascade)
}

model GlobalConfig {
  id                     String   @id @default("system")
  systemName             String   @default("ConextBot")
  maintenanceMode        Boolean  @default(false)
  googleClientId         String?
  googleClientSecret     String?
  openaiApiKey           String?
  geminiApiKey           String?
  asaasApiKey            String?
  elevenLabsApiKey       String?
  openrouterApiKey       String?
  updatedAt              DateTime @updatedAt
  supportEmail           String?
  supportWhatsapp        String?
  asaasWalletId          String?
  smtpFrom               String?
  smtpHost               String?
  smtpPass               String?
  smtpPort               Int?
  smtpUser               String?
  systemBotId            String?
  logoColoredUrl         String?
  logoWhiteUrl           String?
  mercadoPagoAccessToken String?
  stripePublishableKey   String?
  stripeSecretKey        String?
}

enum UserRole {
  USER
  ADMIN
  SUPERADMIN
}

enum SchedulingProvider {
  INTERNAL
  GOOGLE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
}

enum ProductType {
  SINGLE
  RECURRING
}

enum BillingPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  SEMIANNUAL
}

enum PlanInterval {
  MONTHLY
  YEARLY
  QUARTERLY
  SEMIANNUAL
}

enum SplitType {
  FIXED
  PERCENTAGE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
  PENDING
  TRIALING
  FREE
}

enum PaymentStatus {
  PENDING
  RECEIVED
  CONFIRMED
  OVERDUE
  REFUNDED
  PAID
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // INFO, WARNING, SUCCESS, ERROR, HUMAN_REQUESTED, AI_DETECTED
  title     String
  content   String
  read      Boolean  @default(false)
  tenantId  String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum FunnelStage {
  LEAD
  AWARENESS
  INTEREST
  CONSIDERATION
  DECISION
  ACTION
  CUSTOMER
  SUPPORT
  CHURNED
}
