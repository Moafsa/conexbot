generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              Tenant  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Tenant   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  USER
  ADMIN
  SUPERADMIN
}

model Tenant {
  id                      String         @id @default(uuid())
  name                    String?
  email                   String         @unique
  password                String?
  whatsapp                String?        @unique
  cpfCnpj                 String?
  role                    UserRole       @default(USER)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  notificationPreferences String?
  botLimit                Int            @default(1)
  asaasApiKey             String?
  openaiApiKey            String?
  geminiApiKey            String?
  openrouterApiKey        String?
  elevenLabsApiKey        String?
  accounts                Account[]
  bots                    Bot[]
  contacts                Contact[]
  payments                Payment[]
  sessions                Session[]
  subscription            Subscription?
  usageCounter            UsageCounter?
  smtpConfigs             SmtpConfig[]
  botMaterials            BotMaterial[]
  followupRules           FollowupRule[]
}

model Bot {
  id                String         @id @default(uuid())
  name              String
  businessType      String
  voiceId           String?
  modules           String[]
  status            String         @default("active")
  sessionName       String?        @unique
  address           String?
  hours             String?
  paymentMethods    String[]
  knowledgeBase     String?
  description       String?
  productsServices  String?
  websiteUrl        String?
  scrapedContent    String?
  lastScrapedAt     DateTime?
  enablePayments    Boolean        @default(false)
  fallbackContact   String?
  systemPrompt      String?
  aiProvider        String         @default("openai")
  aiModel           String         @default("gpt-4o-mini")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tenantId          String
  connectionStatus  String         @default("DISCONNECTED")
  webhookToken      String?
  webhookUrl        String?
  chatwootAccountId String?
  chatwootToken     String?
  chatwootUrl       String?
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  media             BotMedia[]
  conversations     Conversation[]
  orders            Order[]
  products          Product[]
  vectors           VectorStore[]
  crmStages         CrmStage[]
  contacts          Contact[]
  assignedContacts  Contact[]      @relation("AssignedBot")
  smtpConfigs       SmtpConfig[]
  materials         BotMaterial[]
  followupRules     FollowupRule[]
}

model SmtpConfig {
  id        String   @id @default(uuid())
  host      String
  port      Int
  user      String
  pass      String
  fromEmail String
  active    Boolean  @default(true)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  botId     String?
  bot       Bot?     @relation(fields: [botId], references: [id])
  createdAt DateTime @default(now())
}

model FollowupRule {
  id          String   @id @default(uuid())
  name        String
  triggerDays Int      @default(1)
  triggerType String   @default("AFTER_LAST_MESSAGE") // SALES, POST_SALE, EVENT_REMINDER
  message     String
  active      Boolean  @default(true)
  botId       String
  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model BotMaterial {
  id            String   @id @default(uuid())
  name          String
  type          String // PDF, DOCX, TXT, IMAGE
  contentUrl    String
  extractedText String?
  botId         String
  bot           Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model CrmStage {
  id          String    @id @default(uuid())
  name        String
  color       String    @default("gray")
  order       Int       @default(0)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  botId       String
  bot         Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  contacts    Contact[]

  @@unique([botId, name])
}

model BotMedia {
  id            String    @id @default(uuid())
  type          String
  filename      String
  url           String
  description   String?
  extractedText String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  botId         String
  bot           Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String?
  price       Float
  currency    String      @default("BRL")
  sku         String?
  stock       Int         @default(0)
  imageUrl    String?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  botId       String
  orderItems  OrderItem[]
  bot         Bot         @relation(fields: [botId], references: [id], onDelete: Cascade)
}

model Order {
  id          String      @id @default(uuid())
  status      String      @default("PENDING")
  totalAmount Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  botId       String
  contactId   String
  bot         Bot         @relation(fields: [botId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  items       OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Float
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Contact {
  id            String    @id @default(uuid())
  phone         String
  name          String?
  email         String?
  company       String?
  role          String?
  needs         String?
  notes         String?
  tags          String[]
  funnelStage   String    @default("LEAD")
  lastActive    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenantId      String
  botId         String?
  stageId       String?
  eventDate     DateTime?
  assignedBotId String?
  lastAiInsight String?
  leadScore     Int       @default(0)
  sentiment     String?
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bot           Bot?      @relation(fields: [botId], references: [id], onDelete: Cascade)
  assignedBot   Bot?      @relation("AssignedBot", fields: [assignedBotId], references: [id], onDelete: SetNull)
  stage         CrmStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  orders        Order[]

  @@unique([phone, botId])
}

model Conversation {
  id        String    @id @default(uuid())
  channel   String
  remoteId  String
  status    String    @default("open")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  botId     String
  bot       Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([botId, remoteId])
}

model Message {
  id             String       @id @default(uuid())
  content        String
  role           String
  createdAt      DateTime     @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Plan {
  id            String         @id @default(uuid())
  name          String
  description   String?
  price         Float
  interval      PlanInterval   @default(MONTHLY)
  botLimit      Int            @default(1)
  messageLimit  Int            @default(500)
  active        Boolean        @default(true)
  externalId    String? // ID do plano no Asaas
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

model Subscription {
  id         String             @id @default(uuid())
  status     SubscriptionStatus
  gateway    String             @default("ASAAS")
  externalId String?            @unique
  tenantId   String             @unique
  planId     String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan       Plan?              @relation(fields: [planId], references: [id], onDelete: SetNull)
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
}

model Payment {
  id         String        @id @default(uuid())
  amount     Float
  status     PaymentStatus
  gateway    String        @default("ASAAS")
  externalId String?       @unique
  invoiceUrl String?
  tenantId   String
  createdAt  DateTime      @default(now())
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum PaymentStatus {
  PENDING
  RECEIVED
  CONFIRMED
  OVERDUE
  REFUNDED
}

model UsageCounter {
  id            String   @id @default(uuid())
  messagesUsed  Int      @default(0)
  messagesLimit Int      @default(500)
  botsUsed      Int      @default(0)
  botsLimit     Int      @default(1)
  periodStart   DateTime @default(now())
  periodEnd     DateTime
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model VectorStore {
  id        String                 @id @default(uuid())
  content   String
  metadata  Json?
  embedding Unsupported("vector")?
  botId     String
  createdAt DateTime               @default(now())
  bot       Bot                    @relation(fields: [botId], references: [id], onDelete: Cascade)
}

enum FunnelStage {
  LEAD
  AWARENESS
  INTEREST
  CONSIDERATION
  DECISION
  ACTION
  CUSTOMER
  SUPPORT
  CHURNED
}
model GlobalConfig {
  id                 String   @id @default("system")
  systemName         String   @default("ConextBot")
  maintenanceMode    Boolean  @default(false)
  
  // Google Auth (Configurável via SuperAdmin)
  googleClientId     String?
  googleClientSecret String?
  
  // Fallback Keys
  openaiApiKey       String?
  geminiApiKey       String?
  asaasApiKey        String?
  elevenLabsApiKey   String?
  
  updatedAt          DateTime @updatedAt
}
